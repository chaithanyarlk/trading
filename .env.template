# ==============================================================================
# AI Trading System - Environment Configuration Template
# ==============================================================================

# ============= CLAUDE AI CONFIGURATION =============
# Get from: https://console.anthropic.com/

CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxx
CLAUDE_MODEL=claude-3-opus-20250729

# ============= GROWW API CONFIGURATION =============
# Get from: https://developers.groww.in/

GROWW_API_KEY=your-groww-api-key
GROWW_API_SECRET=your-groww-api-secret
GROWW_AUTH_TOKEN=your-groww-auth-token
GROWW_API_BASE_URL=https://api.groww.in/v1

# ============= TRADING MODE CONFIGURATION =============
# LIVE_TRADING=false means paper trading (simulation)
# LIVE_TRADING=true means real trading (requires verified Groww account)

LIVE_TRADING=false
LIVE_TRADING_ENABLED=false

# ============= PAPER TRADING CONFIGURATION =============
# Initial capital for simulated trading

PAPER_TRADING_INITIAL_CAPITAL=1000000

# ============= APPLICATION CONFIGURATION =============

APP_NAME=AI Trading Assistant
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO

# ============= DATABASE CONFIGURATION =============
# Optional: For storing trade history and portfolio data

DATABASE_URL=sqlite:///./trading.db

# ============= MARKET DATA CONFIGURATION =============
# Data provider settings

MARKET_DATA_PROVIDER=groww
MARKET_DATA_CACHE_DURATION=60

# ============= API SERVER CONFIGURATION =============

API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# ============= FRONTEND CONFIGURATION =============

REACT_APP_API_URL=http://localhost:8000
REACT_APP_ENV=development

# ==============================================================================
# SETUP INSTRUCTIONS
# ==============================================================================
#
# 1. Create a .env file in the project root with the values above
#
# 2. Get Anthropic API Key:
#    - Go to https://console.anthropic.com/
#    - Create Account/Login
#    - Navigate to API Keys
#    - Create new key
#    - Paste value in CLAUDE_API_KEY=
#
# 3. Get Groww API Credentials:
#    - Go to https://developers.groww.in/
#    - Sign up for developer account
#    - Create application
#    - Get API Key, Secret, Auth Token
#    - Fill in GROWW_API_* values
#
# 4. Start Backend:
#    cd backend
#    python -m uvicorn app.main:app --reload
#
# 5. Start Frontend:
#    cd frontend
#    npm start
#
# 6. Test at: http://localhost:3000
#
# ==============================================================================
